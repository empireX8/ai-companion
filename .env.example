# Copy this file to .env and fill in real values.
# Never commit .env to git — it is already in .gitignore.
# Never paste secrets into chat or share them publicly.
# If you accidentally expose a key, rotate it immediately.

# ── Database ─────────────────────────────────────────────────────────────────
# Option A — Local Docker (use `npm run db:local` to start the container):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/companion"

# Option B — Remote Postgres (Neon / Supabase / Railway / etc.):
# DATABASE_URL="postgresql://user:password@your-host.neon.tech/companion?sslmode=require"

# ── Auth (Clerk) ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── Other services (fill in as needed) ───────────────────────────────────────
# OPENAI_API_KEY=sk-...
# STRIPE_API_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=...
# PINECONE_API_KEY=...
# UPSTASH_REDIS_REST_URL=...
# UPSTASH_REDIS_REST_TOKEN=...
