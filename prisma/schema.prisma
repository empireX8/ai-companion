generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id         String      @id @default(uuid())
  name       String
  companions Companion[]
}

model Companion {
  id           String    @id @default(uuid())
  userId       String
  userName     String
  src          String
  name         String
  description  String
  instructions String
  seed         String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  categoryId   String
  category     Category  @relation(fields: [categoryId], references: [id])
  messages     Message[]

  @@index([categoryId])
}

model Session {
  id                        String              @id @default(uuid())
  userId                    String
  label                     String?
  origin                    SessionOrigin       @default(APP)
  surfaceType               SessionSurfaceType?
  importedSource            String?
  importedAt                DateTime?
  importedExternalId        String?
  startedAt                 DateTime            @default(now())
  endedAt                   DateTime?
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt
  messages                  Message[]
  referenceItemsFromSession ReferenceItem[]     @relation("ReferenceItemSourceSession")
  contradictionNodes        ContradictionNode[]

  @@unique([userId, importedExternalId])
  @@index([userId])
  @@index([userId, startedAt])
  @@index([userId, origin, createdAt])
  @@index([userId, origin, surfaceType, startedAt])
}

model Message {
  id                        String              @id @default(uuid())
  sessionId                 String
  userId                    String
  role                      Role
  content                   String
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt
  companionId               String?
  companion                 Companion?          @relation(fields: [companionId], references: [id], onDelete: SetNull)
  session                   Session             @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  referenceItemsFromMessage ReferenceItem[]     @relation("ReferenceItemSourceMessage")
  contradictionNodes        ContradictionNode[]
  evidenceSpans             EvidenceSpan[]

  @@index([sessionId, createdAt])
  @@index([userId, createdAt])
  @@index([companionId])
}

model JournalEntry {
  id                   String                 @id @default(uuid())
  userId               String
  title                String?
  body                 String
  authoredAt           DateTime?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  patternClaimEvidence PatternClaimEvidence[]

  @@index([userId, createdAt])
  @@index([userId, updatedAt])
}

model UserSubscription {
  id                     String    @id @default(cuid())
  userId                 String    @unique
  stripeCustomerId       String?   @unique @map("stripe_customer_id")
  stripeSubscriptionId   String?   @unique @map("stripe_subscription_id")
  stripePriceId          String?   @map("stripe_price_id")
  stripeCurrentPeriodEnd DateTime? @map("stripe_current_period_end")
}

model StripeEvent {
  id          String   @id
  processedAt DateTime @default(now())
}

model WeeklyAudit {
  id                      String    @id @default(cuid())
  userId                  String
  weekStart               DateTime
  generatedAt             DateTime  @default(now())
  status                  String    @default("draft") // "draft" | "locked"
  lockedAt                DateTime?
  inputHash               String?
  activeReferenceCount    Int
  openContradictionCount  Int
  totalContradictionCount Int
  top3AvgComputedWeight   Float
  top3Ids                 String[]
  totalAvoidanceCount     Int
  totalSnoozeCount        Int
  contradictionDensity    Float
  stabilityProxy          Float
  top3Snapshot            Json?

  @@unique([userId, weekStart])
  @@index([userId, generatedAt])
  @@index([userId, status])
}

model ReferenceItem {
  id                 String                       @id @default(uuid())
  userId             String
  type               ReferenceType
  confidence         ReferenceConfidence
  status             ReferenceStatus
  statement          String
  sourceSessionId    String?
  sourceMessageId    String?
  supersedesId       String?
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt
  sourceSession      Session?                     @relation("ReferenceItemSourceSession", fields: [sourceSessionId], references: [id], onDelete: SetNull)
  sourceMessage      Message?                     @relation("ReferenceItemSourceMessage", fields: [sourceMessageId], references: [id], onDelete: SetNull)
  supersedes         ReferenceItem?               @relation("ReferenceItemSupersedes", fields: [supersedesId], references: [id], onDelete: SetNull)
  supersededBy       ReferenceItem[]              @relation("ReferenceItemSupersedes")
  contradictionLinks ContradictionReferenceLink[]

  @@index([userId, status])
  @@index([userId, type])
  @@index([sourceSessionId])
  @@index([sourceMessageId])
}

model ContradictionNode {
  id              String                  @id @default(cuid())
  userId          String
  title           String
  sideA           String
  sideB           String
  type            ContradictionType
  confidence      ReferenceConfidence     @default(low)
  status          ContradictionStatus     @default(open)
  weight          Float                   @default(0)
  snoozeCount     Int                     @default(0)
  timesSurfaced   Int                     @default(0)
  lastSurfacedAt  DateTime?
  lastEvidenceAt  DateTime?
  evidenceCount   Int                     @default(0)
  recommendedRung ProbeRung?
  escalationLevel Int                     @default(0)
  avoidanceCount  Int                     @default(0)
  lastEscalatedAt DateTime?
  lastAvoidedAt   DateTime?
  rung            ProbeRung?
  snoozedUntil    DateTime?
  createdAt       DateTime                @default(now())
  lastTouchedAt   DateTime                @default(now())
  sourceSessionId String?
  sourceMessageId String?
  sourceSession   Session?                @relation(fields: [sourceSessionId], references: [id], onDelete: SetNull)
  sourceMessage   Message?                @relation(fields: [sourceMessageId], references: [id], onDelete: SetNull)
  evidence        ContradictionEvidence[]
  referenceLinks  ContradictionReferenceLink[]

  @@index([userId, status, weight])
  @@index([userId, lastTouchedAt])
  @@index([userId, escalationLevel, weight])
  @@index([userId, lastEscalatedAt])
  @@index([userId, createdAt])
}

model ContradictionReferenceLink {
  id              String            @id @default(cuid())
  contradictionId String
  referenceId     String
  asserted        Boolean           @default(false)
  assertedAt      DateTime?
  createdAt       DateTime          @default(now())
  contradiction   ContradictionNode @relation(fields: [contradictionId], references: [id], onDelete: Cascade)
  reference       ReferenceItem     @relation(fields: [referenceId], references: [id], onDelete: Cascade)

  @@unique([contradictionId, referenceId])
  @@index([contradictionId])
  @@index([referenceId])
}

model ContradictionEvidence {
  id        String            @id @default(cuid())
  nodeId    String
  node      ContradictionNode @relation(fields: [nodeId], references: [id], onDelete: Restrict)
  source    String            @default("user_input")
  sessionId String?
  messageId String?
  quote     String?
  createdAt DateTime          @default(now())

  @@index([nodeId])
}

model ImportUploadSession {
  id                      String               @id @default(cuid())
  userId                  String
  filename                String
  contentType             String
  bytesTotal              BigInt
  chunkSize               Int
  totalChunks             Int
  status                  ImportUploadStatus   @default(pending)
  processingProgress      Int                  @default(0)
  processedConversations  Int                  @default(0)
  processedMessages       Int                  @default(0)
  sessionsCreated         Int                  @default(0)
  messagesCreated         Int                  @default(0)
  contradictionsCreated   Int                  @default(0)
  resultErrors            String[]
  error                   String?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  startedAt               DateTime?
  finishedAt              DateTime?
  chunks                  ImportUploadChunk[]

  @@index([userId, createdAt])
}

model ImportUploadChunk {
  id         String              @id @default(cuid())
  sessionId  String
  chunkIndex Int
  sizeBytes  Int
  checksum   String?
  createdAt  DateTime            @default(now())
  session    ImportUploadSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, chunkIndex])
  @@index([sessionId, createdAt])
}

enum SessionOrigin {
  APP
  IMPORTED_ARCHIVE
}

enum SessionSurfaceType {
  journal_chat
  explore_chat
}

enum Role {
  user
  assistant
  system
}

enum ReferenceType {
  constraint
  pattern
  goal
  preference
  assumption
  hypothesis
  rule
  source
}

enum ReferenceConfidence {
  low
  medium
  high
}

enum ReferenceStatus {
  candidate
  active
  superseded
  inactive
  dismissed
}

enum ContradictionType {
  goal_behavior_gap
  value_conflict
  constraint_conflict
  belief_conflict
  pattern_loop
  narrative_conflict
}

enum ContradictionStatus {
  candidate
  open
  snoozed
  explored
  resolved
  accepted_tradeoff
  archived_tension
}

enum ProbeRung {
  rung1_gentle_mirror
  rung2_explicit_contradiction
  rung3_evidence_pressure
  rung4_forced_choice_framing
  rung5_structured_probe_offer
}

enum ImportUploadStatus {
  pending
  uploading
  uploaded
  processing
  complete
  failed
  expired
}

// ── Internal Metrics ─────────────────────────────────────────────────────────

model InternalMetricEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String
  sessionId String?
  name      String
  level     String   @default("info") // "info" | "warn" | "error"
  value     Float?
  meta      Json?
  source    String   // "client" | "server"
  route     String?
  dedupeKey String?

  @@index([userId, createdAt])
  @@index([name])
  @@index([userId, name])
  @@index([dedupeKey])
}

// ── Derivation Layer ─────────────────────────────────────────────────────────

model DerivationRun {
  id                  String               @id @default(uuid())
  userId              String
  scope               String               // "import" | "native" | "manual"
  processorVersion    String
  inputMessageSetHash String
  status              String               @default("created") // "created" | "running" | "completed" | "failed"
  // Batch orchestration metadata (populated by pattern batch orchestrator)
  messageCount        Int?
  sessionCount        Int?
  windowStart         DateTime?
  windowEnd           DateTime?
  createdAt           DateTime             @default(now())
  artifacts           DerivationArtifact[]

  @@index([userId, createdAt])
  @@index([scope])
}

model EvidenceSpan {
  id                  String   @id @default(uuid())
  userId              String
  messageId           String
  message             Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  charStart           Int
  charEnd             Int
  contentHash         String
  createdAt           DateTime @default(now())
  artifactLinks       ArtifactEvidenceLink[]
  profileArtifactLinks ProfileArtifactEvidenceLink[]

  @@unique([messageId, charStart, charEnd, contentHash])
  @@index([userId, messageId])
  @@index([userId, createdAt])
}

model DerivationArtifact {
  id              String               @id @default(uuid())
  userId          String
  runId           String
  run             DerivationRun        @relation(fields: [runId], references: [id], onDelete: Cascade)
  type            String
  status          String               @default("candidate") // "candidate" | "promoted" | "rejected"
  payload         Json
  confidenceScore Float?
  temporalStart   DateTime?
  temporalEnd     DateTime?
  createdAt       DateTime             @default(now())
  evidenceLinks   ArtifactEvidenceLink[]
  promotionLinks  ArtifactPromotionLink[]

  @@index([userId, type])
  @@index([runId])
}

model ArtifactEvidenceLink {
  artifactId String
  spanId     String
  role       String?
  artifact   DerivationArtifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  span       EvidenceSpan       @relation(fields: [spanId], references: [id], onDelete: Cascade)

  @@id([artifactId, spanId])
}

model ArtifactPromotionLink {
  artifactId  String
  entityType  String
  entityId    String
  createdAt   DateTime           @default(now())
  artifact    DerivationArtifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)

  @@unique([entityType, entityId])
  @@id([artifactId, entityType, entityId])
  @@index([artifactId])
}

// ── Profile Artifacts ─────────────────────────────────────────────────────────

model ProfileArtifact {
  id           String                      @id @default(uuid())
  userId       String
  type         ProfileArtifactType
  claim        String
  claimNorm    String                      // normalized for dedup
  confidence   Float                       @default(0.5)
  status       String                      @default("candidate") // "candidate" | "active" | "superseded"
  firstSeenAt  DateTime                    @default(now())
  lastSeenAt   DateTime                    @default(now())
  tags         String[]
  evidenceLinks ProfileArtifactEvidenceLink[]

  @@unique([userId, type, claimNorm])
  @@index([userId, type])
  @@index([userId, status])
  @@index([userId, lastSeenAt])
}

model ProfileArtifactEvidenceLink {
  artifactId  String
  spanId      String
  artifact    ProfileArtifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  span        EvidenceSpan    @relation(fields: [spanId], references: [id], onDelete: Cascade)

  @@id([artifactId, spanId])
}

// ── Projection Nodes ──────────────────────────────────────────────────────────

enum ProjectionStatus {
  active
  archived
  resolved
}

enum ResolutionVerdict {
  correct
  incorrect
  mixed
}

model Projection {
  id                String             @id @default(cuid())
  userId            String
  premise           String
  drivers           String[]
  outcomes          String[]
  confidence        Float              @default(0.5)
  status            ProjectionStatus   @default(active)
  resolutionVerdict ResolutionVerdict?
  resolutionNote    String?
  resolvedAt        DateTime?
  sourceSessionId   String?
  sourceMessageId   String?
  createdAt         DateTime           @default(now())

  @@index([userId, createdAt])
  @@index([userId, status])
}

enum ProfileArtifactType {
  BELIEF
  VALUE
  GOAL
  FEAR
  IDENTITY
  TRAIT
  HABIT
  TOPIC
  RELATIONSHIP_PATTERN
  EMOTIONAL_PATTERN
  COGNITIVE_PATTERN
}

// ── Quick Check-Ins ───────────────────────────────────────────────────────────

enum QuickCheckInStateTag {
  overloaded
  stressed
  flat
  stable
  energized
}

model QuickCheckIn {
  id        String               @id @default(cuid())
  userId    String
  stateTag  QuickCheckInStateTag?
  eventTags String[]             @default([])
  note      String?              @db.VarChar(160)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([userId, createdAt])
}

// ── Pattern Claims ────────────────────────────────────────────────────────────
// V1 core surface. LOCKED enums — changes require schema migration + build gate
// update in lib/__tests__/pattern-build-gates.test.ts.

enum PatternType {
  trigger_condition
  inner_critic
  repetitive_loop
  contradiction_drift
  recovery_stabilizer
}

enum PatternClaimStatus {
  candidate
  active
  paused
  dismissed
}

enum StrengthLevel {
  tentative
  developing
  established
}

enum SurfacedActionBucket {
  stabilize
  build
}

enum SurfacedActionStatus {
  not_started
  done
  helped
  didnt_help
}

model PatternClaim {
  id                String               @id @default(cuid())
  userId            String
  patternType       PatternType
  strengthLevel     StrengthLevel        @default(tentative)
  status            PatternClaimStatus   @default(candidate)
  summary           String
  summaryNorm       String               // normalized for dedup, via normalizeSummary()
  sourceRunId       String?
  // P2.5-07 — set true when a not_helpful action outcome is recorded;
  // consumed + cleared by batchRefreshClaimsForUser on next refresh pass.
  needsReevaluation    Boolean              @default(false)
  journalEvidenceCount Int                @default(0)
  journalEntrySpread   Int                @default(0)
  journalDaySpread     Int                @default(0)
  supportContainerSpread Int              @default(0)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  evidence          PatternClaimEvidence[]
  actions           PatternClaimAction[]

  @@unique([userId, patternType, summaryNorm])
  @@index([userId, status])
  @@index([userId, patternType])
  @@index([userId, createdAt])
  @@index([userId, needsReevaluation])
}

// ── Pattern Claim Actions ─────────────────────────────────────────────────────
// Claim-attached lightweight micro-experiments. No due dates, no reminders,
// no streaks. One active action per claim at a time (enforced by query logic).

model PatternClaimAction {
  id             String       @id @default(cuid())
  claimId        String
  userId         String
  prompt         String
  status         String       @default("pending") // pending | in_progress | completed | skipped | abandoned
  outcomeSignal  String?      // helpful | not_helpful | unclear
  reflectionNote String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  completedAt    DateTime?
  claim          PatternClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
  @@index([userId, status])
  @@index([userId, createdAt])
}

model SurfacedAction {
  id              String               @id @default(cuid())
  userId          String
  surfaceKey      String
  templateId      String
  bucket          SurfacedActionBucket
  linkedFamily    PatternType?
  linkedClaimId   String?
  linkedGoalRefId String?
  status          SurfacedActionStatus @default(not_started)
  note            String?
  surfacedAt      DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@unique([userId, surfaceKey])
  @@index([userId, bucket, updatedAt])
  @@index([userId, linkedClaimId])
  @@index([userId, linkedGoalRefId])
}

// Mirrors ContradictionEvidence — reuse shape, not a third evidence concept.
// Fields: claimId (≙ nodeId), source, sessionId, messageId, quote, createdAt
model PatternClaimEvidence {
  id             String       @id @default(cuid())
  claimId        String
  claim          PatternClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)
  source         String       @default("derivation") // "derivation" | "user_input"
  sessionId      String?
  messageId      String?
  journalEntryId String?
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)
  quote          String?
  createdAt      DateTime     @default(now())

  @@index([claimId])
  @@index([journalEntryId])
}
